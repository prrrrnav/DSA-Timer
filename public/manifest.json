{
  "manifest_version": 3,
  "name": "DSA Timebox Pro",
  "version": "1.0",
  "description": "Strict 45-minute phase timer for problem solving.",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "tabs",
    "identity"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://api.github.com/*",
    "https://github.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "index.html",
    "default_title": "Open Timebox"
  },
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/problems/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "oauth2": {
    "client_id": "279164720081-40s67rvjrf25lg9rsp3mqn286s0lbqdn.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/userinfo.profile"
    ]
  }
}