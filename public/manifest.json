{
  "manifest_version": 3,
  "name": "DSA Timebox Pro",
  "version": "1.0",
  "description": "Strict 45-minute phase timer for problem solving.",
  "permissions": ["storage", "alarms", "notifications"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "index.html",
    "default_title": "Open Timebox"
  }
}